generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum MessageStatus {
  streaming
  completed
  failed
}

enum ParseStatus {
  queued
  processing
  completed
  failed
}

enum FileAssetKind {
  spreadsheet
  document
  image
}

enum RunStatus {
  queued
  running
  completed
  failed
}

enum ApiStyle {
  openai_compatible
  openai_responses
  anthropic_messages
}

enum ArtifactType {
  markdown
  json
}

model User {
  id            String               @id @default(cuid())
  login         String               @unique
  displayName   String
  passwordHash  String
  role          UserRole             @default(user)
  enabled       Boolean              @default(true)
  conversations Conversation[]
  folders       ConversationFolder[]
  files         FileAsset[]
  runs          Run[]
  artifacts     Artifact[]
  auditLogs     AuditLog[]           @relation("AuditActor")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id                   String              @id @default(cuid())
  userId               String
  folderId             String?
  sectionId            String              @default("network-engineer")
  title                String
  lastMessageAt        DateTime?
  defaultProviderId    String?
  defaultModelConfigId String?
  deletedAt            DateTime?
  user                 User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  folder               ConversationFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  defaultProvider      ProviderConfig?     @relation(fields: [defaultProviderId], references: [id], onDelete: SetNull)
  defaultModel         ModelConfig?        @relation(fields: [defaultModelConfigId], references: [id], onDelete: SetNull)
  messages             Message[]
  runs                 Run[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([userId, deletedAt, lastMessageAt])
  @@index([folderId, lastMessageAt])
}

model ConversationFolder {
  id            String         @id @default(cuid())
  userId        String
  name          String
  sortOrder     Int            @default(0)
  deletedAt     DateTime?
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, deletedAt, sortOrder])
}

model Message {
  id                    String              @id @default(cuid())
  conversationId        String
  role                  MessageRole
  status                MessageStatus       @default(completed)
  content               String
  providerId            String?
  modelConfigId         String?
  providerResponseModel String?
  errorMessage          String?
  conversation          Conversation        @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  provider              ProviderConfig?     @relation(fields: [providerId], references: [id], onDelete: SetNull)
  modelConfig           ModelConfig?        @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  runs                  Run[]
  attachments           MessageAttachment[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([conversationId, createdAt])
}

model FileAsset {
  id                 String              @id @default(cuid())
  ownerId            String
  kind               FileAssetKind       @default(spreadsheet)
  originalName       String
  mimeType           String
  sizeBytes          Int
  storageKey         String              @unique
  parseStatus        ParseStatus         @default(queued)
  parseAttempts      Int                 @default(0)
  parseError         String?
  deletedAt          DateTime?
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  index              FileIndex?
  messageAttachments MessageAttachment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId, deletedAt, parseStatus])
}

model MessageAttachment {
  id          String    @id @default(cuid())
  messageId   String
  fileAssetId String
  sortOrder   Int       @default(0)
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Restrict)
  fileAsset   FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@unique([messageId, fileAssetId])
  @@index([messageId, sortOrder])
  @@index([fileAssetId])
}

model FileIndex {
  id                    String    @id @default(cuid())
  fileAssetId           String    @unique
  sheetSummaries        Json
  columnSummaries       Json
  sampleRows            Json
  chunks                Json
  deterministicFindings Json?
  embeddingStatus       String?
  fileAsset             FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Run {
  id             String          @id @default(cuid())
  userId         String
  toolId         String
  conversationId String?
  messageId      String?
  providerId     String?
  modelConfigId  String?
  status         RunStatus       @default(queued)
  inputFileIds   Json?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  conversation   Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?        @relation(fields: [messageId], references: [id], onDelete: SetNull)
  provider       ProviderConfig? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  modelConfig    ModelConfig?    @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  artifacts      Artifact[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, status, createdAt])
}

model Artifact {
  id            String       @id @default(cuid())
  ownerId       String
  runId         String
  title         String
  type          ArtifactType
  storageKey    String?
  inlineContent String?
  deletedAt     DateTime?
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  run           Run          @relation(fields: [runId], references: [id], onDelete: Restrict)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([ownerId, deletedAt, createdAt])
}

model ProviderConfig {
  id              String         @id @default(cuid())
  name            String         @unique
  baseUrl         String
  apiStyle        ApiStyle       @default(openai_compatible)
  apiKeyEncrypted String
  apiKeyMasked    String
  enabled         Boolean        @default(true)
  models          ModelConfig[]
  conversations   Conversation[]
  messages        Message[]
  runs            Run[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ModelConfig {
  id                  String         @id @default(cuid())
  providerId          String
  modelId             String
  displayName         String
  supportsStreaming   Boolean        @default(true)
  supportsEmbeddings  Boolean        @default(false)
  supportsFiles       Boolean        @default(false)
  supportsImages      Boolean        @default(false)
  supportsNativeFiles Boolean        @default(false)
  supportsJsonMode    Boolean        @default(false)
  enabled             Boolean        @default(true)
  isDefault           Boolean        @default(false)
  sortOrder           Int            @default(0)
  maxInputTokens      Int?
  notes               String?
  provider            ProviderConfig @relation(fields: [providerId], references: [id], onDelete: Restrict)
  conversations       Conversation[]
  messages            Message[]
  runs                Run[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([providerId, modelId])
  @@index([providerId, enabled, sortOrder])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json
  actor       User     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
}
